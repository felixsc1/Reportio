# App
APP_ENV=development
LOG_LEVEL=INFO
REPORTIO_CACHE_TTL_SECONDS=300

# Bexio OAuth / API
BEXIO_CLIENT_ID=your_client_id
BEXIO_CLIENT_SECRET=your_client_secret
BEXIO_REDIRECT_URI=http://localhost:8501
BEXIO_AUTH_BASE_URL=https://auth.bexio.com/realms/bexio
BEXIO_OAUTH_SCOPE=kb_invoice_show kb_order_show offline_access
BEXIO_API_BASE_URL=https://api.bexio.com/2.0

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
