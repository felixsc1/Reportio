# App
APP_ENV=development
LOG_LEVEL=INFO
REPORTIO_CACHE_TTL_SECONDS=300

# Bexio PAT / API
BEXIO_PAT=your_personal_access_token
BEXIO_API_BASE_URL=https://api.bexio.com/2.0
BEXIO_ACCOUNTING_API_BASE_URL=https://api.bexio.com/3.0
BEXIO_PURCHASE_API_BASE_URL=https://api.bexio.com/4.0

# Personio API (non-interactive auth via client credentials)
PERSONIO_CLIENT_ID=your_personio_client_id
PERSONIO_CLIENT_SECRET=your_personio_client_secret
PERSONIO_API_BASE_URL=https://api.personio.de/v1

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama (local models)
OLLAMA_BASE_URL=http://localhost:11434
